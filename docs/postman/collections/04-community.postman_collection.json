                "type": "text/javascript",
                "exec": [
                  "const mediaUrl = pm.environment.get('headerImageUrl') || pm.environment.get('oldUploadUrl') || pm.environment.get('galleryMediaUrl');",
                  "if (mediaUrl) pm.environment.set('galleryMediaUrl', mediaUrl);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "const id = json?.data?.id;",
                  "if (id !== undefined && id !== null) pm.environment.set('galleryItemId', String(id));"
                ]
              }
