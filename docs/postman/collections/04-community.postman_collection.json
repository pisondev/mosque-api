      "name": "00. Events",
      "item": [
        {
          "name": "GET /tenant/events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/events?page=1&limit=10&category={{eventCategory}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "events"],
