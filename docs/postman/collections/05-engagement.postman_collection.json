      "name": "00. Static Payment Methods",
      "item": [
        {
          "name": "GET /tenant/static-payment-methods",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/static-payment-methods?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "static-payment-methods"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "List channel donasi statis tenant."
          },
          "response": []
        },
        {
          "name": "POST /tenant/static-payment-methods",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('paymentMethodLabel', `Channel ${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "const id = json?.data?.id;",
                  "if (id !== undefined && id !== null) pm.environment.set('paymentMethodId', String(id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel_type\": \"{{paymentChannelType}}\",\n  \"label\": \"{{paymentMethodLabel}}\",\n  \"bank_name\": \"Bank Syariah Indonesia\",\n  \"bank_branch\": \"Cabang Surabaya\",\n  \"account_number\": \"1234567890\",\n  \"account_holder_name\": \"Masjid Etakmir\",\n  \"qris_image_url\": \"{{headerImageUrl}}\",\n  \"merchant_id\": \"MID-ETAKMIR-001\",\n  \"description\": \"Channel donasi utama\",\n  \"sort_order\": 1,\n  \"is_public\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/static-payment-methods",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "static-payment-methods"]
            },
            "description": "Membuat channel donasi statis dan menyimpan `paymentMethodId`."
          },
          "response": []
        },
        {
          "name": "GET /tenant/static-payment-methods/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
