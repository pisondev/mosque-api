          },
          "response": []
        },
        {
          "name": "GET /tenant/website-features",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/website-features",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "website-features"]
            },
            "description": "List konfigurasi website feature tenant."
          },
          "response": []
        },
        {
          "name": "PUT /tenant/website-features/:feature_id",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true,\n  \"is_active\": true,\n  \"detail\": \"{{featureDetail}}\",\n  \"note\": \"Update single feature dari Postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/website-features/{{featureId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "website-features", "{{featureId}}"]
            },
            "description": "Update satu feature website berdasarkan `featureId`."
          },
          "response": []
        },
        {
          "name": "PATCH /tenant/website-features/bulk",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"feature_id\": {{featureId}},\n      \"enabled\": true,\n      \"is_active\": true,\n      \"detail\": \"{{featureDetail}}\",\n      \"note\": \"Bulk update item 1\"\n    },\n    {\n      \"feature_id\": {{featureId}},\n      \"enabled\": true,\n      \"is_active\": false,\n      \"detail\": \"{{featureDetail}}\",\n      \"note\": \"Bulk update item 2 - contoh payload, ganti feature_id lain bila perlu\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/website-features/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "website-features", "bulk"]
            },
            "description": "Bulk update website features. Sebaiknya ganti item kedua dengan `feature_id` berbeda dari hasil katalog."
          },
          "response": []
