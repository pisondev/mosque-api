            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/management-members?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "management-members"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}]
            },
            "description": "List pengurus public."
          },
          "response": []
        }
      ]
    },
