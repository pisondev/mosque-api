{
  "info": {
    "_postman_id": "09367a10-30f4-44e4-a798-82ed151fdbd1",
    "name": "Etakmir - 07 Public",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Endpoint public website untuk event, galeri, pengurus, channel donasi, social link, external link, campaign, donor, dan donate."
  },
  "item": [
    {
      "name": "00. Community Public",
      "item": [
        {
          "name": "GET /public/:hostname/events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/events?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "events"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}]
            },
            "description": "List event public berdasarkan hostname tenant."
          },
          "response": []
        },
        {
          "name": "GET /public/:hostname/gallery/albums",
          "request": {
