    {
      "name": "02. Campaign Public",
      "item": [
        {
          "name": "GET /public/:hostname/campaigns",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/campaigns?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "campaigns"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}]
            },
            "description": "List campaign public."
          },
          "response": []
        },
        {
          "name": "GET /public/:hostname/campaigns/:slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/campaigns/{{campaignSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "campaigns", "{{campaignSlug}}"]
            },
            "description": "Detail campaign public berdasarkan slug."
          },
          "response": []
        },
        {
          "name": "GET /public/:hostname/campaigns/:id/donors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/campaigns/{{campaignId}}/donors?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "campaigns", "{{campaignId}}", "donors"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}]
            },
            "description": "List donor public untuk campaign tertentu. Hanya transaksi paid yang tampil."
          },
          "response": []
        },
        {
          "name": "POST /public/:hostname/campaigns/:id/donate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donor_name\": \"{{donorName}}\",\n  \"is_anonymous\": false,\n  \"amount\": {{donationAmount}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/public/{{publicHostname}}/campaigns/{{campaignId}}/donate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "public", "{{publicHostname}}", "campaigns", "{{campaignId}}", "donate"]
            },
            "description": "Membuat checkout donasi public. Minimal `donationAmount` adalah 10000 dan campaign harus aktif serta PG config tersedia."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": []
}
