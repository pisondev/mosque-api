              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "prayer-times-daily"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "from", "value": "{{worshipDate}}" },
