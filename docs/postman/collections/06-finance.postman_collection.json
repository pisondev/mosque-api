    {
      "name": "02. Campaigns",
      "item": [
        {
          "name": "GET /tenant/campaigns",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/campaigns?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "campaigns"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "List campaign donasi tenant. Route ini butuh fitur `pg_digital` aktif."
          },
          "response": []
        },
        {
          "name": "POST /tenant/campaigns",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const title = `Campaign ${Date.now()}`;",
                  "pm.environment.set('campaignTitle', title);",
                  "pm.environment.set('campaignSlug', title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, ''));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json?.data?.id;",
                  "const slug = json?.data?.slug;",
                  "if (id !== undefined && id !== null) pm.environment.set('campaignId', String(id));",
                  "if (slug) pm.environment.set('campaignSlug', slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{campaignTitle}}\",\n  \"slug\": \"{{campaignSlug}}\",\n  \"description\": \"Campaign penggalangan dana dari Postman\",\n  \"image_url\": \"{{headerImageUrl}}\",\n  \"target_amount\": {{campaignTargetAmount}},\n  \"start_date\": \"2026-04-17T00:00:00Z\",\n  \"end_date\": \"2026-05-17T00:00:00Z\",\n  \"is_active\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/campaigns",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "campaigns"]
            },
            "description": "Membuat campaign donasi tenant dan menyimpan `campaignId` serta `campaignSlug`. Route ini butuh fitur `pg_digital` aktif."
          },
          "response": []
        },
        {
          "name": "GET /tenant/campaigns/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/campaigns/{{campaignId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "campaigns", "{{campaignId}}"]
            },
            "description": "Detail campaign donasi tenant. Butuh fitur `pg_digital` aktif."
          },
          "response": []
        },
        {
          "name": "PUT /tenant/campaigns/:id",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{campaignTitle}} Updated\",\n  \"slug\": \"{{campaignSlug}}\",\n  \"description\": \"Campaign penggalangan dana versi update\",\n  \"image_url\": \"{{headerImageUrl}}\",\n  \"target_amount\": {{campaignTargetAmount}},\n  \"start_date\": \"2026-04-17T00:00:00Z\",\n  \"end_date\": \"2026-06-01T00:00:00Z\",\n  \"is_active\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/campaigns/{{campaignId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "campaigns", "{{campaignId}}"]
            },
            "description": "Update campaign donasi tenant. Butuh fitur `pg_digital` aktif."
          },
          "response": []
        },
        {
          "name": "GET /tenant/campaigns/:id/transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/campaigns/{{campaignId}}/transactions?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "campaigns", "{{campaignId}}", "transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "List transaksi campaign tenant. Butuh fitur `pg_digital` aktif."
          },
          "response": []
        }
      ]
    }
