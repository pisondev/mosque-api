{
  "info": {
    "_postman_id": "9f654549-aa42-4b8b-a872-1645a70f3dc5",
    "name": "Etakmir - 01 Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Module auth untuk bootstrap akun admin, login, reset password, dan Google Sign-In."
  },
  "item": [
    {
      "name": "00. Session Bootstrap",
      "item": [
        {
          "name": "Register Admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const autoGenerate = (pm.environment.get('autoGenerateRegisterEmail') || 'true').toLowerCase() === 'true';",
                  "const currentEmail = pm.environment.get('registerEmail');",
                  "if (autoGenerate || !currentEmail) {",
                  "  pm.environment.set('registerEmail', `admin+${Date.now()}@example.com`);",
                  "}",
                  "pm.environment.set('email', pm.environment.get('registerEmail'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response status is success', function () {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "const token = json?.data?.access_token;",
                  "const email = json?.data?.email;",
                  "if (token) pm.environment.set('bearerToken', token);",
                  "if (email) pm.environment.set('email', email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Mendaftarkan tenant dan user admin baru. Secara default email digenerate unik per request."
          },
          "response": []
        },
        {
          "name": "Login Email Password",
