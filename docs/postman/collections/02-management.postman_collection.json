    {
      "name": "01. Domains",
      "item": [
        {
          "name": "GET /tenant/domains",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/domains?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "domains"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "List domain tenant aktif/pending."
          },
          "response": []
        },
        {
          "name": "POST /tenant/domains",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const autoGenerate = (pm.environment.get('autoGenerateDomainHostname') || 'true').toLowerCase() === 'true';",
                  "if (autoGenerate) {",
                  "  pm.environment.set('domainHostname', `tenant-${Date.now()}.localtest.me`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('domain created', function () {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "const domainId = json?.data?.id;",
                  "if (domainId !== undefined && domainId !== null) pm.environment.set('domainId', String(domainId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"domain_type\": \"{{domainType}}\",\n  \"hostname\": \"{{domainHostname}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/domains",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "domains"]
            },
            "description": "Menambahkan domain tenant. Hostname default dibuat unik per eksekusi jika auto generate aktif."
          },
          "response": []
        },
        {
          "name": "PATCH /tenant/domains/:id",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/domains/{{domainId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "domains", "{{domainId}}"]
            },
            "description": "Mengubah status domain tenant tertentu."
          },
          "response": []
        },
        {
          "name": "DELETE /tenant/domains/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/domains/{{domainId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "domains", "{{domainId}}"]
            },
            "description": "Cleanup domain tenant. Jalankan jika ingin menghapus data uji."
          },
          "response": []
        }
      ]
    },
