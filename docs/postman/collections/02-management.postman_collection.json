        {
          "name": "DELETE /tenant/tags/:id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/tags/{{tagId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "tags", "{{tagId}}"]
