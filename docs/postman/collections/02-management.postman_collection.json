  "item": [
    {
      "name": "00. Tenant Context",
      "item": [
        {
          "name": "GET /tenant/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('tenant context loaded', function () {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "me"]
            },
            "description": "Mengambil konteks tenant dari JWT aktif."
          },
          "response": []
        },
        {
          "name": "PATCH /tenant/setup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('tenant setup successful', function () {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.environment.set('publicHostname', `${pm.environment.get('tenantSubdomain')}.localhost`);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
