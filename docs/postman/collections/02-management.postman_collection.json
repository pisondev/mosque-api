    {
      "name": "06. Media",
      "item": [
        {
          "name": "GET /tenant/storage-quota",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/storage-quota",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "storage-quota"]
            },
            "description": "Melihat pemakaian storage tenant saat ini."
          },
          "response": []
        },
        {
          "name": "POST /tenant/upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const url = json?.data?.url;",
                  "if (url) {",
                  "  pm.environment.set('oldUploadUrl', url);",
                  "  if ((pm.environment.get('uploadKind') || 'header') === 'header') {",
                  "    pm.environment.set('headerImageUrl', url);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "old_url",
                  "value": "{{oldUploadUrl}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/upload?kind={{uploadKind}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "upload"],
              "query": [
                {
                  "key": "kind",
                  "value": "{{uploadKind}}"
                }
              ]
            },
            "description": "Upload file gambar multipart. Pilih file manual di field `file`. `uploadKind` mendukung `header`, `management_photo`, `event_poster`, dan `qris`."
          },
          "response": []
        }
      ]
