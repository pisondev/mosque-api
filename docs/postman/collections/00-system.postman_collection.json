  "item": [
    {
      "name": "Health",
      "description": "Pengecekan cepat untuk memastikan API dan koneksi database siap.",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('response status is success', function () {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('health payload has database state', function () {",
                  "  pm.expect(json.data.database).to.eql('up');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Health check publik untuk memastikan backend dan database sedang tersedia."
          },
          "response": []
        },
